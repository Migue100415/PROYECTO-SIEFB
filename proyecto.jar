
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

public class DatabaseConnection {

    private static final String URL = "jdbc:mysql://localhost:3306/club_deportivo";
    private static final String USER = "root";
    private static final String PASSWORD = "123456";

    public static Connection getConnection() throws SQLException {
        return DriverManager.getConnection(URL, USER, PASSWORD);
    }
}


import java.sql.Connection;
import java.sql.SQLException;

public abstract class BaseDAO {

    protected Connection getConnection() throws SQLException {
        return DatabaseConnection.getConnection();
    }
}


import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class PersonaDAO extends BaseDAO {

    // CREATE
    public int crearPersona(String documento, String nombre, String direccion,
                            String telefono, String actaMedica,
                            String eps, String foto, Date fechaNacimiento) {

        String sql = "INSERT INTO PERSONA (documento, nombre, direccion, telefono, acta_medica, eps, foto, fecha_nacimiento) VALUES (?, ?, ?, ?, ?, ?, ?, ?)";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {

            ps.setString(1, documento);
            ps.setString(2, nombre);
            ps.setString(3, direccion);
            ps.setString(4, telefono);
            ps.setString(5, actaMedica);
            ps.setString(6, eps);
            ps.setString(7, foto);
            ps.setDate(8, fechaNacimiento);

            ps.executeUpdate();

            ResultSet rs = ps.getGeneratedKeys();
            if (rs.next()) {
                return rs.getInt(1);
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
        return -1;
    }

    // READ
    public void listarPersonas() {
        String sql = "SELECT * FROM PERSONA";

        try (Connection conn = getConnection();
             Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {

            while (rs.next()) {
                System.out.println(rs.getInt("id") + " - " + rs.getString("nombre"));
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // UPDATE
    public void actualizarPersona(int id, String nombre) {
        String sql = "UPDATE PERSONA SET nombre=? WHERE id=?";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, nombre);
            ps.setInt(2, id);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // DELETE
    public void eliminarPersona(int id) {
        String sql = "DELETE FROM PERSONA WHERE id=?";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, id);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}

import java.sql.*;

public class JugadorDAO extends BaseDAO {

    // CREATE
    public void crearJugador(int personaId, String acudiente, Date fecha) {

        String sql = "INSERT INTO JUGADOR (id, nombre_acudiente, dia_inscripcion) VALUES (?, ?, ?)";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, personaId);
            ps.setString(2, acudiente);
            ps.setDate(3, fecha);

            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // READ
    public void listarJugadores() {
        String sql = """
                SELECT p.id, p.nombre, j.nombre_acudiente
                FROM PERSONA p
                JOIN JUGADOR j ON p.id = j.id
                """;

        try (Connection conn = getConnection();
             Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {

            while (rs.next()) {
                System.out.println(rs.getInt("id") + " - " + rs.getString("nombre"));
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // UPDATE
    public void actualizarAcudiente(int id, String acudiente) {
        String sql = "UPDATE JUGADOR SET nombre_acudiente=? WHERE id=?";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, acudiente);
            ps.setInt(2, id);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    // DELETE
    public void eliminarJugador(int id) {
        String sql = "DELETE FROM JUGADOR WHERE id=?";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, id);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}

import java.sql.*;

public class TrabajadorDAO extends BaseDAO {

    public void crearTrabajador(int personaId, String arl, Date fechaIngreso) {

        String sql = "INSERT INTO TRABAJADOR (id, arl, dia_ingreso) VALUES (?, ?, ?)";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, personaId);
            ps.setString(2, arl);
            ps.setDate(3, fechaIngreso);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    public void listarTrabajadores() {
        String sql = """
                SELECT p.id, p.nombre, t.arl
                FROM PERSONA p
                JOIN TRABAJADOR t ON p.id = t.id
                """;

        try (Connection conn = getConnection();
             Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {

            while (rs.next()) {
                System.out.println(rs.getInt("id") + " - " + rs.getString("nombre"));
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }

    public void eliminarTrabajador(int id) {
        String sql = "DELETE FROM TRABAJADOR WHERE id=?";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, id);
            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}

