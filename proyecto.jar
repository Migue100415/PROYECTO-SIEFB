import java.sql.*;

public class PartidoDAO extends BaseDAO {

    public int crear(Date fecha, String arbitro, String cancha, String rival) {

        String sql = "INSERT INTO PARTIDO (fecha, nombre_arbitro, nombre_cancha, equipo_rival) VALUES (?, ?, ?, ?)";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {

            ps.setDate(1, fecha);
            ps.setString(2, arbitro);
            ps.setString(3, cancha);
            ps.setString(4, rival);

            ps.executeUpdate();

            ResultSet rs = ps.getGeneratedKeys();
            if (rs.next()) return rs.getInt(1);

        } catch (SQLException e) {
            e.printStackTrace();
        }
        return -1;
    }

    public void listar() {
        String sql = "SELECT * FROM PARTIDO";

        try (Connection conn = getConnection();
             Statement st = conn.createStatement();
             ResultSet rs = st.executeQuery(sql)) {

            while (rs.next()) {
                System.out.println(rs.getInt("id") + " - " + rs.getDate("fecha"));
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}


import java.sql.*;

public class EntrenamientoDAO extends BaseDAO {

    public int crear(Date fecha, String observaciones) {

        String sql = "INSERT INTO ENTRENAMIENTO (fecha, observaciones) VALUES (?, ?)";

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {

            ps.setDate(1, fecha);
            ps.setString(2, observaciones);
            ps.executeUpdate();

            ResultSet rs = ps.getGeneratedKeys();
            if (rs.next()) return rs.getInt(1);

        } catch (SQLException e) {
            e.printStackTrace();
        }
        return -1;
    }
}


import java.sql.*;

public class JugadorPartidoDAO extends BaseDAO {

    public void registrarParticipacion(int jugadorId, int partidoId,
                                       int goles, int asistencias,
                                       int amarillas, int rojas,
                                       boolean asistencia) {

        String sql = """
            INSERT INTO JUGADOR_PARTIDO 
            (jugador_id, partido_id, goles, asistencias, amarillas, rojas, asistencia)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        """;

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, jugadorId);
            ps.setInt(2, partidoId);
            ps.setInt(3, goles);
            ps.setInt(4, asistencias);
            ps.setInt(5, amarillas);
            ps.setInt(6, rojas);
            ps.setBoolean(7, asistencia);

            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}


import java.sql.*;

public class JugadorEntrenamientoDAO extends BaseDAO {

    public void registrar(int jugadorId, int entrenamientoId, boolean asistencia) {

        String sql = """
            INSERT INTO JUGADOR_ENTRENAMIENTO 
            (jugador_id, entrenamiento_id, asistencia)
            VALUES (?, ?, ?)
        """;

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, jugadorId);
            ps.setInt(2, entrenamientoId);
            ps.setBoolean(3, asistencia);

            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}


import java.sql.*;

public class RegistroContableDAO extends BaseDAO {

    public void registrar(Date fecha, int cantidad, String comprobante,
                          String tipo, int adminId) {

        String sql = """
            INSERT INTO REGISTRO_CONTABLE 
            (fecha, cantidad_pago, comprobante, tipo, administrador_id)
            VALUES (?, ?, ?, ?, ?)
        """;

        try (Connection conn = getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setDate(1, fecha);
            ps.setInt(2, cantidad);
            ps.setString(3, comprobante);
            ps.setString(4, tipo);
            ps.setInt(5, adminId);

            ps.executeUpdate();

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}







